# ── Auth (Clerk) ────────────────────────────────────────────────
# Publishable key from the Clerk dashboard (starts with pk_test_ / pk_live_).
# This is a client-side key and is safe to expose in the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=

# ── Database + Storage (Supabase) ───────────────────────────────
# Project URL and ANON (public) key from Supabase → Project Settings → API.
# The anon key is designed for client use; access is enforced by RLS.
# NEVER put the Supabase service_role key here or anywhere client-side.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Runtime mode ────────────────────────────────────────────────
# Leave all three false for production. VITE_LOCAL_DEV=true and
# VITE_USE_MOCK_DATA=true are for local development only.
VITE_LOCAL_DEV=false
VITE_USE_MOCK_DATA=false
VITE_MAINTENANCE_MODE=false

# ── Server / API (server-side only — never bundled to the client) ─
# Supabase service_role key — FULL database access, BYPASSES all RLS.
# Used only by server.ts to write the trusted market_prices table (bug #22).
# NEVER prefix with VITE_, never expose to the browser, never commit the value.
SUPABASE_SERVICE_ROLE_KEY=
PORT=5173
HMR_PORT=24680
DISABLE_HMR=false
# Transactional email (Resend). RESEND_FROM_EMAIL must be a verified sender
# (the API refuses to send without it — see MIGRATION_NOTES.md bug #16).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional AI features (Google Gemini), used by the /api/markets-adjacent tooling.
GEMINI_API_KEY=
# Branding used in transactional emails.
ORBITRIO_COMPANY_NAME=Orbitrio Trades
ORBITRIO_SUPPORT_EMAIL=support@orbitriotrades.com
ORBITRIO_LOGO_URL=
# Comma-separated allowlist of origins permitted to call /api/send-email.
ORBITRIO_ALLOWED_ORIGINS=https://your-domain.example
