rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == "henrikaram1@gmail.com" ||
        firestore.exists(/databases/(default)/documents/users/$(request.auth.token.email)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.token.email)).data.role == "admin"
      );
    }

    function isSafeUpload() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches("image/.*|application/pdf");
    }

    match /kyc/{fileName} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && isSafeUpload();
    }

    match /deposits/{fileName} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && isSafeUpload();
    }

    match /deposit-wallets/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isSafeUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
