rules_version = '2';
service cloud.firestore {
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == "admin";
    }

    // Public site content texts read access, write limited to admin
    match /site_content/texts {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public master traders read access, write limited to admin
    match /traders/{traderId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Investment Plans
    match /investment_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profile matching document read/write access
    match /users/{email} {
      allow read, write: if request.auth != null && (request.auth.token.email.toLowerCase() == email.toLowerCase() || isAdmin());
    }

    // Fallback global rules for general collections (e.g. logs), restricted to logged in users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
