rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public site content texts read access, write limited to admin
    match /site_content/texts {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "henrikaram1@gmail.com";
    }

    // Public master traders read access, write limited to admin
    match /traders/{traderId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "henrikaram1@gmail.com";
    }

    // User profile matching document read/write access
    match /users/{email} {
      allow read, write: if request.auth != null && request.auth.token.email.toLowerCase() == email.toLowerCase();
    }

    // Fallback global rules for general collections (e.g. logs), restricted to logged in users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
