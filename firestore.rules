rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.token.email.toLowerCase())).data.role == "admin";
    }

    // Public site content texts read access, write limited to admin
    match /site_content/texts {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public master traders read access, write limited to admin
    match /traders/{traderId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Investment Plans
    match /investment_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profile matching document read/write access
    match /users/{email} {
      allow read, write: if request.auth != null && (request.auth.token.email.toLowerCase() == email.toLowerCase() || isAdmin());
    }

    match /admin_settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }
    
    match /airdrops/{airdropId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /airdrop_claims/{claimId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
