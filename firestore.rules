rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email.toLowerCase() == email.toLowerCase();
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.toLowerCase() == "henrikaram1@gmail.com" ||
        (userDoc().exists() && userDoc().data.role == "admin")
      );
    }

    match /site_content/texts {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /traders/{traderId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /investment_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{email} {
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(email) || isAdmin();
      allow update: if isAdmin() || (
        isOwner(email) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.isAdmin == resource.data.isAdmin
      );
      allow delete: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /transactions/{txId} {
      allow read, write: if isAdmin();
    }

    match /copyTrades/{tradeId} {
      allow create: if isAuthenticated() && request.resource.data.uid.toLowerCase() == request.auth.token.email.toLowerCase();
      allow get, delete: if isAuthenticated() && resource.data.uid.toLowerCase() == request.auth.token.email.toLowerCase();
      allow update: if false;
      allow list: if isAdmin();
    }

    match /airdrops/{airdropId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /airdrop_claims/{claimId} {
      allow create: if isAuthenticated() && request.resource.data.userEmail.toLowerCase() == request.auth.token.email.toLowerCase();
      allow get: if isAdmin() || (isAuthenticated() && resource.data.userEmail.toLowerCase() == request.auth.token.email.toLowerCase());
      allow list: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.userEmail.toLowerCase() == request.auth.token.email.toLowerCase() &&
        request.resource.data.status == resource.data.status
      );
      allow delete: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
