{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "entities": {
    "SiteContent": {
      "title": "SiteContent",
      "description": "Dynamic editable site content text values",
      "type": "object",
      "properties": {
        "hero_title": { "type": "string" },
        "hero_subtitle": { "type": "string" },
        "hero_button": { "type": "string" },
        "dashboard_title": { "type": "string" },
        "dashboard_description": { "type": "string" },
        "investment_title": { "type": "string" },
        "investment_description": { "type": "string" },
        "footer_text": { "type": "string" },
        "announcement_text": { "type": "string" },
        "faq_question_1": { "type": "string" },
        "faq_answer_1": { "type": "string" },
        "faq_question_2": { "type": "string" },
        "faq_answer_2": { "type": "string" },
        "faq_question_3": { "type": "string" },
        "faq_answer_3": { "type": "string" }
      },
      "required": ["hero_title", "hero_subtitle"]
    },
    "Trader": {
      "title": "Trader",
      "description": "Master Trader copy portfolio profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "roi": { "type": "number" },
        "winRate": { "type": "number" },
        "followers": { "type": "number" },
        "maxFollowers": { "type": "number" },
        "assetsUnderManagement": { "type": "string" },
        "riskScore": { "type": "number" },
        "profitDays": { "type": "number" },
        "chartData": {
          "type": "array",
          "items": { "type": "number" }
        }
      },
      "required": ["name", "roi", "winRate"]
    }
  },
  "firestore": {
    "site_content/texts": {
      "schema": { "$ref": "#/entities/SiteContent" },
      "description": "Dynamic text mapping values for UI widgets"
    },
    "traders/{traderId}": {
      "schema": { "$ref": "#/entities/Trader" },
      "description": "Collection of master traders available for copy trading"
    }
  }
}
